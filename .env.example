# Discord application token (Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=replace_with_your_discord_bot_token

# Your externally hosted Lavalink v4 node.
# For multiple nodes, use matching comma-separated values in each variable.
LAVALINK_HOSTS=127.0.0.1
LAVALINK_PORTS=2333
LAVALINK_PASSWORDS=replace_with_your_lavalink_password
LAVALINK_SECURES=false
